# Convex - obtén la URL en https://dashboard.convex.dev tras ejecutar `bun run dev` en apps/backend
NEXT_PUBLIC_CONVEX_URL=

# Dominio raíz del SaaS: solo aquí existe /superadmin (ej. mezzi.app).
# Subdominios tenant (urbrands.mezzi.app, alcarbon.mezzi.app) no pueden abrir el panel admin.
NEXT_PUBLIC_SAAS_HOST=mezzi.app
#cloud
# Google Calendar (para sincronizar reservas)
# Obtén credenciales en https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# URL del deployment Convex (ej: https://tu-deploy.convex.site) para OAuth callback
NEXT_PUBLIC_CONVEX_SITE=

VOICE_INTEGRATION_ID=

# Variables para Convex (Convex Dashboard > Settings > Environment Variables):
# GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET - credenciales OAuth
# FRONTEND_URL - URL del frontend (ej: http://localhost:3000) para redirect tras OAuth


